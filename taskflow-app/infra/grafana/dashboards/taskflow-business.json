{
  "id": null,
  "uid": "taskflow-business",
  "title": "TaskFlow - Métriques métier",
  "tags": ["taskflow", "business"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Tâches créées par minute",
      "id": 1,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(tasks_created_total[5m])) * 60",
          "legendFormat": "tasks/min"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm"
        },
        "overrides": []
      }
    },
    {
      "type": "piechart",
      "title": "Répartition des tâches créées par priorité (5m)",
      "id": 2,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (priority) (increase(tasks_created_total[5m]))",
          "legendFormat": "{{priority}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Transitions de statut par minute (fenêtre 5m)",
      "id": 3,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (from_status, to_status) (rate(tasks_status_changes_total[5m])) * 60",
          "legendFormat": "{{from_status}} → {{to_status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Tentatives de connexion réussies vs échouées (par minute)",
      "id": 4,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (success) (rate(user_login_attempts_total[5m])) * 60",
          "legendFormat": "success={{success}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm"
        },
        "overrides": []
      }
    }
  ]
}
