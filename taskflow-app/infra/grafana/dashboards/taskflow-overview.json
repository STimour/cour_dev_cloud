{
  "id": null,
  "uid": "taskflow-overview",
  "title": "TaskFlow - Vue d'ensemble des services",
  "tags": ["taskflow", "overview"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Taux de requêtes par service (req/s)",
      "id": 1,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (job) (rate(http_requests_total{job=~\"api-gateway|user-service|task-service|notification-service\"}[5m]))",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Latence HTTP p50/p95/p99 (ms)",
      "id": 2,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (job, le) (rate(http_request_duration_ms_bucket{job=~\"api-gateway|user-service|task-service|notification-service\"}[5m])))",
          "legendFormat": "p50 {{job}}"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (job, le) (rate(http_request_duration_ms_bucket{job=~\"api-gateway|user-service|task-service|notification-service\"}[5m])))",
          "legendFormat": "p95 {{job}}"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (job, le) (rate(http_request_duration_ms_bucket{job=~\"api-gateway|user-service|task-service|notification-service\"}[5m])))",
          "legendFormat": "p99 {{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Taux d'erreurs 5xx (%)",
      "id": 3,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum by (job) (rate(http_requests_total{job=~\"api-gateway|user-service|task-service|notification-service\",status=~\"5..\"}[5m])) / clamp_min(sum by (job) (rate(http_requests_total{job=~\"api-gateway|user-service|task-service|notification-service\"}[5m])), 0.000001)",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Statut des services (up)",
      "id": 4,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "up{job=~\"api-gateway|user-service|task-service|notification-service\"}",
          "legendFormat": "{{job}}",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    }
  ]
}
